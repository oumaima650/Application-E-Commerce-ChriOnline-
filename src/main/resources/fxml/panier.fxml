<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>

<StackPane stylesheets="@../css/panier.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.PanierController" style="-fx-background-color: #F4F4F8;" fx:id="rootStackPane">
    <ScrollPane 
        fx:id="panierScrollPane" 
        fitToWidth="true" 
        fitToHeight="false" 
        vbarPolicy="ALWAYS" 
        style="-fx-background-color: transparent; -fx-background: #F4F4F8; -fx-border-width: 0;">
        
        <VBox alignment="TOP_CENTER" style="-fx-background-color: #F4F4F8;">
            <VBox maxWidth="1200" style="-fx-background-color: #FFFFFF;">
                
                <!-- Navbar (Part of the scrollable content) -->
                <HBox styleClass="navbar" spacing="24" alignment="CENTER_LEFT">
                    <Label text="ChriOnline" styleClass="nav-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox spacing="16" alignment="CENTER">
                        <!-- User Auth Section -->
                        <StackPane alignment="CENTER_RIGHT">
                            <children>
                                <!-- Login Button -->
                                <Button fx:id="loginButton" text="Connexion / Inscription" onAction="#handleLoginClick" 
                                        style="-fx-background-color: #FF724C; -fx-text-fill: white; -fx-background-radius: 8px; -fx-font-weight: bold; -fx-padding: 8 16; -fx-cursor: hand;"
                                        visible="false"/>
                                
                                <!-- User Avatar -->
                                <StackPane fx:id="userAvatarContainer" onMouseClicked="#handleUserClick" style="-fx-cursor: hand;" visible="true">
                                    <Circle fx:id="userAvatar" radius="18" fill="#FF724C"/>
                                    <Label fx:id="userInitial" text="U" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                </StackPane>
                            </children>
                        </StackPane>
                    </HBox>
                </HBox>

                <!-- Center Content -->
                <HBox spacing="24" styleClass="cart-container" style="-fx-padding: 24;">
                    <!-- LEFT (60%) -->
                    <VBox spacing="12" HBox.hgrow="ALWAYS" prefWidth="600">
                        <!-- Title HBox -->
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="Mon Panier" styleClass="cart-title"/>
                            <Label fx:id="badgeArticles" text="0 articles" styleClass="cart-badge"/>
                        </HBox>
                        
                        <!-- Items VBox -->
                        <VBox fx:id="panierItemsBox" spacing="8">
                            <!-- Les éléments du panier seront injectés ici dynamiquement -->
                        </VBox>
                        
                        <!-- Bottom HBox -->
                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                            <Hyperlink text="← Continuer mes achats" styleClass="continue-shopping" onAction="#goToHome"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Vider le panier" onAction="#handleViderPanier" style="-fx-background-color: transparent; -fx-text-fill: #E74C3C; -fx-font-weight: bold; -fx-cursor: hand;" />
                        </HBox>
                    </VBox>
                    
                    <!-- RIGHT (40%) -->
                    <VBox styleClass="summary-card" prefWidth="350" minWidth="300">
                        <!-- HEADER -->
                        <HBox styleClass="summary-header" alignment="CENTER_LEFT">
                            <VBox>
                                <Label text="Résumé de commande" styleClass="summary-title"/>
                                <Label text="livraison gratuite" styleClass="summary-subtitle"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <SVGPath content="M5 12h14 M12 5l7 7-7 7" styleClass="summary-arrow"/>
                        </HBox>
                        <!-- BODY -->
                        <VBox styleClass="summary-body" spacing="13">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="Sous-total" styleClass="summary-row-label"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblSousTotal" text="0.00 MAD" styleClass="summary-row-val"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="6">
                                <Label text="Livraison" styleClass="summary-row-label"/>
                                <SVGPath content="M1 3h15v13H1z M16 8h4l3 3v5h-7V8z M5 21a2 2 0 1 0 0-4 2 2 0 0 0 0 4z M17 21a2 2 0 1 0 0-4 2 2 0 0 0 0 4z" styleClass="icon-truck"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="GRATUITE" styleClass="summary-free-val"/>
                            </HBox>
                            
                            <Region styleClass="separator"/>
                            
                            <HBox alignment="CENTER_LEFT">
                                <Label text="TOTAL TTC" styleClass="summary-total-label"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblTotalTTC" text="0.00 MAD" styleClass="summary-total-val"/>
                            </HBox>
                                                
                            <Button fx:id="btnValider" styleClass="btn-cta" maxWidth="Infinity" onAction="#handleValiderCommande">
                                <graphic>
                                    <HBox alignment="CENTER" spacing="8">
                                        <Label text="Valider la commande" styleClass="btn-cta-text"/>
                                        <SVGPath content="M5 12h14 M12 5l7 7-7 7" styleClass="icon-arrow-r"/>
                                    </HBox>
                                </graphic>
                            </Button>
                            
                            <HBox alignment="CENTER" spacing="6" styleClass="secure-container">
                                <SVGPath content="M7 11V7a5 5 0 0 1 10 0v4 M5 11h14a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2z" styleClass="icon-lock"/>
                                <Label text="Paiement 100% sécurisé" styleClass="secure-text"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</StackPane>
