            <!-- TAB 2 : COMMANDES -->
            <Tab text="🛒 Commandes">
                <VBox spacing="15" style="-fx-padding: 20px;">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <TextField fx:id="searchCommandeField" promptText="Filtrer les commandes..." styleClass="input-field" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <TableView fx:id="tableCommandes" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colId" text="ID commande" prefWidth="80"/>
                            <TableColumn fx:id="colClient" text="Client" prefWidth="100"/>
                            <TableColumn fx:id="colDate" text="Date commande" prefWidth="150"/>
                            <TableColumn fx:id="colAdresse" text="Adresse livraison" prefWidth="200"/>
                            <TableColumn fx:id="colTotal" text="Total" prefWidth="100"/>
                            <TableColumn fx:id="colDateLivraisonPrevue" text="Livr. prévue" prefWidth="130"/>
                            <TableColumn fx:id="colDateLivraisonReelle" text="Livr. réelle" prefWidth="130"/>
                            <TableColumn fx:id="colActionsCommande" text="Statut" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- TAB 3 : UTILISATEURS -->
            <Tab text="👥 Utilisateurs">
                <VBox spacing="15" style="-fx-padding: 20px;">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <TextField fx:id="searchClientField" promptText="Rechercher un utilisateur..." styleClass="input-field" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <TableView fx:id="tableClients" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <columns>
                            <TableColumn text="ID" prefWidth="50">
                                <cellValueFactory><PropertyValueFactory property="id" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn text="Nom Comptes" prefWidth="200">
                                <cellValueFactory><PropertyValueFactory property="nom" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn text="Email" prefWidth="200">
                                <cellValueFactory><PropertyValueFactory property="email" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn fx:id="colStatutClient" text="Statut" prefWidth="120"/>
                            <TableColumn fx:id="colActionsClient" text="Actions" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
