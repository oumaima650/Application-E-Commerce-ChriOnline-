<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.shape.Circle?>

<BorderPane style="-fx-background-color: #F4F4F8" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.AdminController">
    <!-- Header Admin -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="navbar" style="-fx-padding: 15px 30px;">
            <Label text="ChriOnline Admin" styleClass="navbar-logo" style="-fx-font-size: 24px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <StackPane fx:id="notifBadge" visible="false">
                <Button text="🔔" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 16px;" onAction="#ouvrirNotifications"/>
                <Circle radius="8" fill="#FF724C" translateX="12" translateY="-10" mouseTransparent="true"/>
                <Label fx:id="notifCount" text="0" style="-fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold;" translateX="12" translateY="-10" mouseTransparent="true"/>
            </StackPane>
            <Button text="Se déconnecter" styleClass="btn-primary"/>
        </HBox>
    </top>

    <!-- Contenu Principal -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: transparent;">
            
            <!-- TAB 1 : PRODUITS (Commenté)
