<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" prefWidth="400.0" prefHeight="500.0" 
      style="-fx-background-color: #f4f7f6; -fx-padding: 40;" 
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="admin_ui.AdminLoginController">
    
    <Text text="Administration" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-fill: #2c3e50;" />
    <Text text="Connexion Sécurisée RSA" style="-fx-font-size: 14px; -fx-fill: #7f8c8d;" />

    <VBox spacing="10.0" alignment="CENTER_LEFT" maxWidth="300">
        <Label text="Email Administrateur" style="-fx-text-fill: #34495e; -fx-font-weight: bold;" />
        <TextField fx:id="emailField" promptText="admin@chrionline.com" 
                   style="-fx-background-radius: 5; -fx-padding: 10;" />
    </VBox>

    <VBox spacing="10.0" alignment="CENTER_LEFT" maxWidth="300">
        <Label text="Mot de passe du Keystore (.p12)" style="-fx-text-fill: #34495e; -fx-font-weight: bold;" />
        <PasswordField fx:id="p12PasswordField" promptText="••••••••" 
                       style="-fx-background-radius: 5; -fx-padding: 10;" />
    </VBox>

    <Button fx:id="loginBtn" text="Se Connecter" onAction="#handleLogin" 
            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 16px; 
                   -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 10 40; -fx-cursor: hand;" />

    <ProgressIndicator fx:id="loadingIndicator" visible="false" />
    <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c;" wrapText="true" alignment="CENTER" />

</VBox>
