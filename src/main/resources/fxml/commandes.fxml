<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<BorderPane styleClass="root" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.CommandesController" stylesheets="@../css/commandes.css">
    <!-- Header -->
    <top>
        <VBox spacing="20" style="-fx-padding: 24px 32px;">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Button text="← Retour" styleClass="btn-back" onAction="#goBack"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Mes Commandes" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="👤 Mon Profil" styleClass="btn-profile" onAction="#goToProfile"/>
                <Button text="↻ Actualiser" styleClass="btn-refresh" onAction="#refreshOrders"/>
            </HBox>
        </VBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <VBox spacing="16" style="-fx-padding: 0 32px 24px 32px;">
            <!-- Filtres et recherche -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Rechercher par référence de votre commande..." styleClass="search-field" HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="statusFilter" promptText="Statut" styleClass="status-filter" prefWidth="150"/>
                <DatePicker fx:id="dateFilter" promptText="Date" styleClass="date-filter" prefWidth="150"/>
            </HBox>

            <!-- TableView des commandes -->
            <TableView fx:id="ordersTable" styleClass="orders-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="refColumn" text="N° Commande" prefWidth="140" />
                    <TableColumn fx:id="dateColumn" text="Date de commande" prefWidth="130" />
                    <TableColumn fx:id="deliveryDateReelleColumn" text="Livraison Réelle" prefWidth="130" />
                    <TableColumn fx:id="totalColumn" text="Total" prefWidth="120" />
                    <TableColumn fx:id="statusColumn" text="Statut" prefWidth="120" />
                    <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="100"/>
                </columns>

                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            </TableView>

            <!-- Pagination -->
            <HBox alignment="CENTER" style="-fx-padding: 16px 0;" spacing="10">
                <Button fx:id="prevBtn" text="←" styleClass="pagination-btn" onAction="#prevPage"/>
                <Label fx:id="paginationLabel" text="Page 1 sur 1" styleClass="pagination-info"/>
                <Button fx:id="nextBtn" text="→" styleClass="pagination-btn" onAction="#nextPage"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
